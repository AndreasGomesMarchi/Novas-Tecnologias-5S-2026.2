   "source": [
    "N = int(input(\"Digite um número: \"))\n",
    "ePrimo = True\n",
    "\n",
    "for i in range(2, N):\n",
    "    if N % i == 0:\n",
    "        ePrimo = False\n",
    "\n",
    "if ePrimo:\n",
    "    print(\"É primo\")\n",
    "else:\n",
    "    print(\"Não é primo\")\n",
    "\n"
   ]
